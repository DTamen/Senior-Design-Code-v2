#include <Stepper.h>
#include <SoftwareSerial.h>
#include <SPI.h>
#include <RH_RF95.h>
#include <RHReliableDatagram.h>
#include <Wire.h>
#include <DFRobot_LIDAR07.h>

// ===== LIDAR =====
DFRobot_LIDAR07_IIC lidar;
uint16_t dist = 0;   // mm

// ===== Pins =====
const int limitSwitchPin = 5;
const int DCIN1 = A0, DCIN2 = A1;
Stepper myStepper(200, A2, A3, A4, A5);

// ===== LoRa =====
#define RFM95_CS 4
#define RFM95_RST 2
#define RFM95_INT 3
#define MAIN_ADDR 1
#define SECONDARY_ADDR 2

#define RH_RF95_MAX_MESSAGE_LEN 16
RH_RF95 rf95(RFM95_CS, RFM95_INT);
RHReliableDatagram manager(rf95, MAIN_ADDR);

// ===== States =====
enum State { IDLE, LOWERING, CHECK_DEPTH, RAISING, ROTATING, FULL };
State currentState = IDLE;

unsigned long stateTimer = 0;
unsigned long lastTelemetry = 0;

uint8_t samples = 0;
uint16_t actionCounter = 0;
uint8_t controllerAddr = 0;

void setup() {
  Serial.begin(9600);

  // ===== I2C Init =====
  Wire.begin();

  if (!lidar.begin()) {
    Serial.println("Lidar init failed!");
    while (1);
  }

  lidar.setMeasureMode(DFRobot_LIDAR07::eLidar07Continuous);
  lidar.setConMeasureFreq(100);
  lidar.startFilter();
  lidar.startMeasure();

  // ===== Motors =====
  myStepper.setSpeed(300);
  pinMode(limitSwitchPin, INPUT);
  pinMode(DCIN1, OUTPUT);
  pinMode(DCIN2, OUTPUT);

  // ===== Reset LoRa =====
  pinMode(RFM95_RST, OUTPUT);
  digitalWrite(RFM95_RST, HIGH);
  delay(10);
  digitalWrite(RFM95_RST, LOW);
  delay(10);
  digitalWrite(RFM95_RST, HIGH);

  if (!manager.init()) while (1);

  rf95.setFrequency(915.0);
  rf95.setTxPower(23, false);
}

void loop() {
  updateDistance();

  // ===== Send Depth Every 500ms =====
  if (millis() - lastTelemetry > 500) {
    sendDepth(dist);
    lastTelemetry = millis();
  }

  // ===== Check for Trigger =====
  uint8_t buf[RH_RF95_MAX_MESSAGE_LEN];
  uint8_t len = sizeof(buf);
  uint8_t from;

  if (manager.recvfromAckTimeout(buf, &len, 10, &from)) {
    if (len >= 1 && buf[0] == 'T' && currentState == IDLE) {
      if (dist >= 500 && dist <= 1500) {   // 0.5m–1.5m
        actionCounter++;
        controllerAddr = from;
        currentState = LOWERING;
        stateTimer = millis();
      }
    }
  }

  runSequence();
}

// ===================================================
// STATE MACHINE
// ===================================================
void runSequence() {
  switch (currentState) {

    case LOWERING:
      digitalWrite(DCIN1, HIGH);
      digitalWrite(DCIN2, LOW);

      if (millis() - stateTimer > 5000) { // 5 seconds
        digitalWrite(DCIN1, HIGH);
        digitalWrite(DCIN2, HIGH); // Stop
        currentState = CHECK_DEPTH;
      }
      break;

    case CHECK_DEPTH:
      if (dist >= 500 && dist <= 1500) {
        currentState = RAISING;
      }
      break;

    case RAISING:
      if (digitalRead(limitSwitchPin) == LOW) {
        digitalWrite(DCIN1, LOW);
        digitalWrite(DCIN2, HIGH);
      } else {
        digitalWrite(DCIN1, HIGH);
        digitalWrite(DCIN2, HIGH); // Stop
        currentState = ROTATING;
      }
      break;

    case ROTATING:
    {
      int steps = (samples < 8) ? (20000 / 8) : (20000 / 16);
      myStepper.step(steps);
      stopStepper();
      samples++;

      sendDone();   // Send after full physical completion

      if (samples >= 8)
        currentState = FULL;
      else
        currentState = IDLE;
    }
      break;

    case FULL:
      Serial.println("Storage Full");
      break;

    case IDLE:
    default:
      break;
  }
}

// ===================================================
// HELPERS
// ===================================================
void stopStepper() {
  digitalWrite(A2, LOW);
  digitalWrite(A3, LOW);
  digitalWrite(A4, LOW);
  digitalWrite(A5, LOW);
}

void sendDone() {
  uint8_t pkt[3]; // 1 header + 2 bytes counter
  pkt[0] = 'K';
  pkt[1] = actionCounter >> 8;
  pkt[2] = actionCounter & 0xFF;
  manager.sendtoWait(pkt, sizeof(pkt), controllerAddr);
}

void sendDepth(uint16_t d) {  // mm
  uint8_t pkt[3]; // 1 header + 2 bytes depth
  pkt[0] = 'D';
  pkt[1] = d >> 8;
  pkt[2] = d & 0xFF;

  static uint8_t seq = 0;
  manager.setHeaderId(++seq);
  manager.sendto(pkt, sizeof(pkt), SECONDARY_ADDR);
}

void updateDistance() {
  if (lidar.getValue()) {
    dist = lidar.getDistanceMM();   // mm
  }
}
