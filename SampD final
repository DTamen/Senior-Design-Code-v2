#include <Stepper.h>
#include <SoftwareSerial.h>
#include <SPI.h>
#include <RH_RF95.h>
#include <RHReliableDatagram.h>

// ─── Tunable Parameters ────────────────────────────────────────────────────
const int TIME_SPENT_BOTTOM   = 20;      // seconds idle at bottom

const unsigned long LOWER_TIME_MS = 3700;  // total time to lower (ms)
const unsigned long RAISE_TIME_MS = 6900;  // total time to raise  (ms)

const int MOTOR_MIN_SPEED = 80;   // PWM 0–255: starting/ending speed (slow)
const int MOTOR_MAX_SPEED_DOWN = 160;  // lowering
const int MOTOR_MAX_SPEED_UP   = 140; // raising

// Ramp occupies this fraction of total travel on each end (0.0–0.5)
const float RAMP_FRACTION = 0.25;
// ──────────────────────────────────────────────────────────────────────────

// Pins
const int limitSwitchPin = 8;
const int DCIN1 = 5, DCIN2 = 6;

SoftwareSerial Serial1(9, 10); // Lidar
Stepper myStepper(200, A2, A3, A4, A5);

#define RFM95_CS 4
#define RFM95_RST 2
#define RFM95_INT 3
#define MAIN_ADDR 1
#define SECONDARY_ADDR 2

float dist = 0;
int strength = 0;
int check = 0;
int i = 0;
int uart[9];
const int HEADER = 0x59;

RH_RF95 rf95(RFM95_CS, RFM95_INT);
RHReliableDatagram manager(rf95, MAIN_ADDR);

// States
enum State { IDLE, LOWERING, CHECK_DEPTH, RAISING, ROTATING, FULL };
State currentState = IDLE;

unsigned long stateTimer = 0;
unsigned long lastTelemetry = 0;

int samples = 0;
uint32_t actionCounter = 0;
uint8_t controllerAddr = 0;

unsigned long bottomTimer = 0;
bool fullNotified = false;

// ─── Speed Profile ────────────────────────────────────────────────────────
/**
 * Returns a PWM speed (MOTOR_MIN_SPEED … MOTOR_MAX_SPEED) for a
 * trapezoidal ramp given:
 *   elapsed  – ms since the move started
 *   total    – total ms for the full move
 *
 * Profile:
 *   0% → RAMP_FRACTION*100%   : ramp UP   (slow → fast)
 *   RAMP_FRACTION → (1-RAMP_FRACTION) : full speed
 *   (1-RAMP_FRACTION) → 100% : ramp DOWN  (fast → slow)
 */
int getMotorSpeed(unsigned long elapsed, unsigned long total, int maxSpeed) {
  float t = (float)elapsed / (float)total;
  t = constrain(t, 0.0f, 1.0f);

  float speedNorm;
  if (t < RAMP_FRACTION) {
    speedNorm = t / RAMP_FRACTION;
  } else if (t < (1.0f - RAMP_FRACTION)) {
    speedNorm = 1.0f;
  } else {
    speedNorm = (1.0f - t) / RAMP_FRACTION;
  }

  return (int)(MOTOR_MIN_SPEED + speedNorm * (maxSpeed - MOTOR_MIN_SPEED));
}
// ─── Motor Helpers ────────────────────────────────────────────────────────
void motorStop() {
  analogWrite(DCIN1, 0);
  digitalWrite(DCIN2, LOW);
}

/** Lower the string (adjust direction to match your wiring) */
void motorLower(int pwmSpeed) {
  analogWrite(DCIN1, pwmSpeed);
  digitalWrite(DCIN2, LOW);
}

/** Raise the string (opposite direction) */
void motorRaise(int pwmSpeed) {
  analogWrite(DCIN1, 255 - pwmSpeed);
  digitalWrite(DCIN2, HIGH);
}
// ──────────────────────────────────────────────────────────────────────────

void setup() {
  Serial.begin(9600);
  Serial1.begin(115200);
  myStepper.setSpeed(300);
  pinMode(limitSwitchPin, INPUT);
  pinMode(DCIN1, OUTPUT); pinMode(DCIN2, OUTPUT);
  
  // Reset Radio
  pinMode(RFM95_RST, OUTPUT); digitalWrite(RFM95_RST, HIGH); delay(10);
  digitalWrite(RFM95_RST, LOW); delay(10); digitalWrite(RFM95_RST, HIGH);
  
  if (!manager.init()) while(1);
  rf95.setFrequency(915.0);
  rf95.setTxPower(23, false);
  
  motorStop();
  Serial.println("System Ready");
}

void loop() {
  dist = measureHeight();

  // Send Depth every 1 second
  if (millis() - lastTelemetry > 500) {
    sendDepth(dist);
    lastTelemetry = millis();
  }

  // Check for Trigger
  uint8_t buf[RH_RF95_MAX_MESSAGE_LEN];
  uint8_t len = sizeof(buf);
  uint8_t from;
  if (manager.recvfromAckTimeout(buf, &len, 10, &from)) {
    if (len >= 1 && buf[0] == 'T' && currentState == IDLE) {
      if (dist >= 50 && dist <= 150) {
        actionCounter++;
        controllerAddr = from;
        currentState = LOWERING;
        stateTimer = millis();
      }
    }
  }

  runSequence();
}

// Helpers
void stopStepper() {
  digitalWrite(A2, LOW); digitalWrite(A3, LOW); 
  digitalWrite(A4, LOW); digitalWrite(A5, LOW);
}

void sendDone() {
  uint16_t samplesToSend = (uint16_t)samples; // Use fixed 2-byte int
  uint8_t pkt[1 + sizeof(uint32_t) + sizeof(uint16_t)];
  pkt[0] = 'K';
  memcpy(&pkt[1], &actionCounter, sizeof(uint32_t));
  memcpy(&pkt[1 + sizeof(uint32_t)], &samplesToSend, sizeof(uint16_t));
  manager.sendtoWait(pkt, sizeof(pkt), controllerAddr);
}

void sendDepth(float d) {
  uint8_t pkt[1 + sizeof(float)];
  pkt[0] = 'D';
  memcpy(&pkt[1], &d, sizeof(float));
  static uint8_t seq = 0;
  manager.setHeaderId(++seq);
  manager.sendto(pkt, sizeof(pkt), SECONDARY_ADDR);
}


float measureHeight()
{
  if (Serial1.available())
  {
    if (Serial1.read() == HEADER)
    {
      uart[0] = HEADER;
      if (Serial1.read() == HEADER)
      {
        uart[1] = HEADER;
        for (i = 2; i < 9; i++)
        {
          uart[i] = Serial1.read();
        }
        check = uart[0] + uart[1] + uart[2] + uart[3] + uart[4] + uart[5] + uart[6] + uart[7];
        if (uart[8] == (check & 0xff))
        {
          dist = uart[2] + uart[3] * 256;
          Serial.print("dist = ");
          Serial.print(dist);
          Serial.print('\n');
        }
      }
    }
  }
  return dist;
}

void runSequence() {
  switch (currentState) {
    case LOWERING:
      digitalWrite(DCIN1, HIGH); digitalWrite(DCIN2, LOW);
      if (millis() - stateTimer > 5000) { // 5s drop
        digitalWrite(DCIN1, HIGH); digitalWrite(DCIN2, HIGH); // Stop
        currentState = CHECK_DEPTH;
      }
      break;

    case CHECK_DEPTH:
      // Stay here until depth is in range
      if (dist >= 50 && dist <= 150) currentState = RAISING;
      break;

    case RAISING:
      if (digitalRead(limitSwitchPin) == LOW) {
        digitalWrite(DCIN1, LOW); digitalWrite(DCIN2, HIGH);
      } else {
        digitalWrite(DCIN1, HIGH); digitalWrite(DCIN2, HIGH); // Stop
        currentState = ROTATING;
      }
      break;

    case ROTATING:
      int steps = (samples < 8) ? (20000/8) : (20000/16);
      myStepper.step(steps);
      stopStepper();
      samples++;
      
      // *** THE FIX: Send DONE only after all physical work is finished ***
      sendDone();
      
      if (samples >= 8) currentState = FULL;
      else currentState = IDLE;
      break;

    case FULL:
      if (!fullNotified) {
      Serial.println("Storage Full");
      sendDone();
      fullNotified = true;
      }
      break;
    }
  }
