#include <Stepper.h>
#include <SoftwareSerial.h>
#include <SPI.h>
#include <RH_RF95.h>
#include <RHReliableDatagram.h>

// ─── Tunable Parameters ────────────────────────────────────────────────────
const int TIME_SPENT_BOTTOM = 20;   // seconds idle at bottom

const unsigned long LOWER_TIME_MS = 3700;  // safety timeout (lowering is based on depth and rotations --not time)
const unsigned long RAISE_TIME_MS = 6900;  // total time to raise  (ms)

const int MOTOR_MIN_SPEED = 80;           // PWM 0–255: starting/ending speed (slow)
const int MOTOR_MAX_SPEED_DOWN = 160;     // lowering
const int MOTOR_MAX_SPEED_UP   = 140;     // raising

const float RAMP_FRACTION = 0.25;         // slope of ramp

//lowering parameters in cm
const float SPOOL_CIRCUMFERENCE_CM = 5.65;   // change to your spool circumference
const float EXTRA_LOWER_OFFSET_CM  = 5.0;    // extra distance to lower past measured depth
const int   HALL_COUNTS_PER_REV    = 1;      // set >1 if your hall sensor gives multiple pulses per rev (do not edit unless you add more magnets to the spool for the motor to register)

const unsigned long RAISE_DECEL_COUNTS = 5;  // tune based on your spool
// ──────────────────────────────────────────────────────────────────────────

// Pins
const int limitSwitchPin = 8;
const int DCIN1 = 5, DCIN2 = 6;
const int hallPin = 7;   // Hall effect sensor pin

SoftwareSerial Serial1(9, 10); // Lidar
Stepper myStepper(200, A2, A3, A4, A5);

#define RFM95_CS 4
#define RFM95_RST 2
#define RFM95_INT 3
#define MAIN_ADDR 1
#define SECONDARY_ADDR 2

float dist = 0;
int strength = 0;
int check = 0;
int i = 0;
int uart[9];
const int HEADER = 0x59;

RH_RF95 rf95(RFM95_CS, RFM95_INT);
RHReliableDatagram manager(rf95, MAIN_ADDR);

// States
enum State { IDLE, LOWERING, CHECK_DEPTH, RAISING, ROTATING, FULL };
State currentState = IDLE;

unsigned long stateTimer = 0;
unsigned long lastTelemetry = 0;
unsigned long bottomTimer = 0;

int samples = 0;
uint32_t actionCounter = 0;
uint8_t controllerAddr = 0;

// Hall sensor counting
unsigned long magnetCount = 0;
int lastHallState = HIGH;

// lowering-tracking variables initialization
float startDepthCm = 0.0;
float targetLowerDistanceCm = 0.0;
unsigned long targetLowerCounts = 0;
unsigned long lastLoweringCount = 0;  // hall counts recorded during lowering

// ─── Speed Profile ────────────────────────────────────────────────────────
int getMotorSpeedLowering(unsigned long currentCount, unsigned long totalCount, int maxSpeed) {
  if (totalCount == 0) return MOTOR_MIN_SPEED;
  float t = (float)currentCount / (float)totalCount;
  t = constrain(t, 0.0f, 1.0f);

  float speedNorm;
  if (t < RAMP_FRACTION) {
    // Ramp up from min → max
    speedNorm = t / RAMP_FRACTION;
  } else if (t < (1.0f - RAMP_FRACTION)) {
    // Hold max
    speedNorm = 1.0f;
  } else {
    // Ramp down max → min
    speedNorm = (1.0f - t) / RAMP_FRACTION;
  }

  return (int)(MOTOR_MIN_SPEED + speedNorm * (maxSpeed - MOTOR_MIN_SPEED));
}

int getMotorSpeedRaising(unsigned long currentCount, unsigned long totalEstimated, int maxSpeed) {
  // Ramp up phase (first RAMP_FRACTION of estimated total)
  unsigned long rampUpCounts = (unsigned long)(totalEstimated * RAMP_FRACTION);
  if (rampUpCounts < 1) rampUpCounts = 1;

  // Decel phase (last RAISE_DECEL_COUNTS)
  unsigned long decelStart = (totalEstimated > RAISE_DECEL_COUNTS)
                              ? totalEstimated - RAISE_DECEL_COUNTS
                              : 0;

  if (currentCount < rampUpCounts) {
    // Ramp up
    float t = (float)currentCount / (float)rampUpCounts;
    return (int)(MOTOR_MIN_SPEED + t * (maxSpeed - MOTOR_MIN_SPEED));
  }
  else if (currentCount >= decelStart && decelStart > 0) {
    // Ramp down toward min for last RAISE_DECEL_COUNTS
    float t = (float)(currentCount - decelStart) / (float)RAISE_DECEL_COUNTS;
    t = constrain(t, 0.0f, 1.0f);
    return (int)(maxSpeed - t * (maxSpeed - MOTOR_MIN_SPEED));
  }
  else {
    // Hold max
    return maxSpeed;
  }
}

// ─── Motor Helpers ────────────────────────────────────────────────────────
void motorStop() {
  analogWrite(DCIN1, 0);
  digitalWrite(DCIN2, LOW);
}

/** Lower the string */
void motorLower(int pwmSpeed) {
  analogWrite(DCIN1, pwmSpeed);
  digitalWrite(DCIN2, LOW);
}

/** Raise the string */
void motorRaise(int pwmSpeed) {
  analogWrite(DCIN1, 255 - pwmSpeed);
  digitalWrite(DCIN2, HIGH);
}

// ─── Hall Counter Helper ──────────────────────────────────────────────────
void updateMagnetCount(bool enableCounting) {
  int currentHallState = digitalRead(hallPin);

  if (!enableCounting) {
    lastHallState = currentHallState;
    return;
  }

  // Count one rotation mark on falling edge
  if (lastHallState == HIGH && currentHallState == LOW) {
    magnetCount++;
    Serial.print("Magnet count: ");
    Serial.println(magnetCount);
  }

  lastHallState = currentHallState;
}

// ─── Lowering Count Calculation ───────────────────────────────────────────
unsigned long computeTargetLowerCounts(float measuredDepthCm) {
  targetLowerDistanceCm = measuredDepthCm + EXTRA_LOWER_OFFSET_CM;

  float revsNeeded = targetLowerDistanceCm / SPOOL_CIRCUMFERENCE_CM;
  float countsNeeded = revsNeeded * HALL_COUNTS_PER_REV;

  // round up so we do not under-lower
  unsigned long result = (unsigned long)(countsNeeded);
  if ((float)result < countsNeeded) {
    result++;
  }

  if (result == 0) result = 1;
  return result;
}

// ─── Setup ────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(9600);
  Serial1.begin(115200);
  myStepper.setSpeed(300);

  pinMode(limitSwitchPin, INPUT);
  pinMode(DCIN1, OUTPUT);
  pinMode(DCIN2, OUTPUT);

  pinMode(hallPin, INPUT_PULLUP);
  lastHallState = digitalRead(hallPin);

  // Reset Radio
  pinMode(RFM95_RST, OUTPUT);
  digitalWrite(RFM95_RST, HIGH);
  delay(10);
  digitalWrite(RFM95_RST, LOW);
  delay(10);
  digitalWrite(RFM95_RST, HIGH);

  if (!manager.init()) while (1);
  rf95.setFrequency(915.0);
  rf95.setTxPower(23, false);

  motorStop();
  Serial.println("System Ready");
}

// ─── Main Loop ────────────────────────────────────────────────────────────
void loop() {
  dist = measureHeight();

  // Send depth every 500 ms
  if (millis() - lastTelemetry > 500) {
    sendDepth(dist);
    lastTelemetry = millis();
  }

  // Check for trigger
  uint8_t buf[RH_RF95_MAX_MESSAGE_LEN];
  uint8_t len = sizeof(buf);
  uint8_t from;

  if (manager.recvfromAckTimeout(buf, &len, 10, &from)) {
    if (len >= 1 && buf[0] == 'T' && currentState == IDLE) {
      if (dist >= 50 && dist <= 150) {
        actionCounter++;
        controllerAddr = from;

        magnetCount = 0;                 
        lastHallState = digitalRead(hallPin);

        // Capture depth at the start of the lowering cycle
        startDepthCm = dist;
        targetLowerCounts = computeTargetLowerCounts(startDepthCm);

        Serial.println("Starting cycle");
        Serial.print("Measured depth (cm): ");
        Serial.println(startDepthCm);
        Serial.print("Target lower distance (cm): ");
        Serial.println(targetLowerDistanceCm);
        Serial.print("Target lower hall counts: ");
        Serial.println(targetLowerCounts);

        currentState = LOWERING;
        stateTimer = millis();
      }
    }
  }

  // Only count while lowering or raising
  bool countEnabled = (currentState == LOWERING || currentState == RAISING);
  updateMagnetCount(countEnabled);

  runSequence();
}

// ─── FSM ──────────────────────────────────────────────────────────────────
void runSequence() {
  switch (currentState) {
    
    case IDLE:
      // Waiting for LoRa trigger in main loop
      break;

    case LOWERING: {
  int speed = getMotorSpeedLowering(magnetCount, targetLowerCounts, MOTOR_MAX_SPEED_DOWN);
  motorLower(speed);

  Serial.print("Lowering | count: "); Serial.print(magnetCount);
  Serial.print(" / "); Serial.print(targetLowerCounts);
  Serial.print(" | PWM: "); Serial.println(speed);

  if (magnetCount >= targetLowerCounts) {
    motorStop();
    lastLoweringCount = magnetCount;  // save for raising ramp estimate
    currentState = CHECK_DEPTH;
    Serial.println("Lowering target reached → CHECK_DEPTH");
  }
  else if (millis() - stateTimer > LOWER_TIME_MS) {
    motorStop();
    lastLoweringCount = magnetCount;  // save even on timeout
    currentState = CHECK_DEPTH;
    Serial.println("Lowering safety timeout → CHECK_DEPTH");
  }
  break;


case CHECK_DEPTH:
  if (dist >= 50 && dist <= 150) {
    magnetCount = 0;          // reset so raising counts from 0
    stateTimer = millis();
    currentState = RAISING;
    Serial.println("Entered RAISING");
  }
  break;

case RAISING: {
  // Use lowering count as best estimate of total raising distance
  int speed = getMotorSpeedRaising(magnetCount, lastLoweringCount, MOTOR_MAX_SPEED_UP);
  motorRaise(speed);

  Serial.print("Raising | count: "); Serial.print(magnetCount);
  Serial.print(" | PWM: "); Serial.println(speed);

  if (digitalRead(limitSwitchPin) == LOW) {
    motorStop();
    Serial.print("Limit switch hit | final count: ");
    Serial.println(magnetCount);
    currentState = ROTATING;
  }
  break;

    case ROTATING: {
      Serial.println("Rotating Carousel...");
      
      // Calculate steps based on how many samples we have already taken
      int steps = (samples < 8) ? (20000 / 8) : (20000 / 16);
      myStepper.step(steps); // Note: This blocks the code until finished
      stopStepper();
      
      samples++;
      sendDone(); // Notify controller

      if (samples >= 8) {
        currentState = FULL;
        Serial.println("System FULL");
      } else {
        currentState = IDLE;
        Serial.println("Ready for next sample.");
      }
    } break;

    case FULL:
      // Simply stay here until a manual reset
      static unsigned long lastFullMsg = 0;
      if (millis() - lastFullMsg > 5000) {
        Serial.println("Storage Full - Empty carousel to continue.");
        lastFullMsg = millis();
      }
      break;
      
    default:
      currentState = IDLE;
      break;
  }
}
// ─── Helpers ──────────────────────────────────────────────────────────────
void stopStepper() {
  digitalWrite(A2, LOW);
  digitalWrite(A3, LOW);
  digitalWrite(A4, LOW);
  digitalWrite(A5, LOW);
}

void sendDone() {
  uint8_t pkt[1 + sizeof(uint32_t)];
  pkt[0] = 'K';
  memcpy(&pkt[1], &actionCounter, sizeof(uint32_t));
  manager.sendtoWait(pkt, sizeof(pkt), controllerAddr);
}

void sendDepth(float d) {
  uint8_t pkt[1 + sizeof(float)];
  pkt[0] = 'D';
  memcpy(&pkt[1], &d, sizeof(float));
  static uint8_t seq = 0;
  manager.setHeaderId(++seq);
  manager.sendto(pkt, sizeof(pkt), SECONDARY_ADDR);
}

float measureHeight() {
  if (Serial1.available()) {
    if (Serial1.read() == HEADER) {
      uart[0] = HEADER;
      if (Serial1.read() == HEADER) {
        uart[1] = HEADER;
        for (i = 2; i < 9; i++) {
          uart[i] = Serial1.read();
        }
        check = uart[0] + uart[1] + uart[2] + uart[3] + uart[4] + uart[5] + uart[6] + uart[7];
        if (uart[8] == (check & 0xff)) {
          dist = uart[2] + uart[3] * 256;
          Serial.print("dist = ");
          Serial.println(dist);
        }
      }
    }
  }
  return dist;
}
